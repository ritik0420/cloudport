############################
# Node / Next.js .gitignore
############################

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
pnpm-lock.yaml
yarn.lock

# Production builds
.next/
out/
build/
dist/

# TypeScript
*.tsbuildinfo

# Logs
logs/
*.log
*.log.*

# OS files
.DS_Store
Thumbs.db

# Env / secrets
.env
.env*.local

# IDE / editor
.vscode/
.idea/
*.swp

# Coverage / tests
coverage/
.nyc_output/

# Misc
.vercel
.turbo
.cache/

